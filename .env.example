# ─── SpacetimeDB Configuration ───────────────────────────────────────────────
# The name of your database module. Use the same name in CLI commands.
SPACETIMEDB_NAME=canal4-prod

# Public WebSocket URI (where the frontend connects).
# - Localhost: ws://your-server-ip:3000
# - Cloud: wss://maincloud.spacetimedb.com
SPACETIMEDB_URI=ws://localhost:3000

# Server address for the `module-init` container to target.
# - Localhost: http://spacetimedb:3000 (Internal Docker network)
# - Cloud: https://maincloud.spacetimedb.com
SPACETIMEDB_SERVER=http://spacetimedb:3000

# 🔴 SECURITY: Publishing Identity Token
# To prevent unauthorized database updates on your self-hosted server, 
# you should set a publishing identity.
#
# How to get your token:
#   1. Run `spacetime login --show` on your dev machine.
#   2. Copy the "Auth Token" for the identity you want to use.
#   3. Paste it below.
#
# If left empty, `module-init` will attempt to publish anonymously.
SPACETIMEDB_IDENTITY_TOKEN=

# ─── Web Dashboard Configuration ─────────────────────────────────────────────
# Public port to expose the web interface.
WEBAPP_PORT=3001

# ─── Database Server Port ────────────────────────────────────────────────────
# External port to expose SpacetimeDB (WebSocket).
# HARDENING TIP: Set this to "127.0.0.1:3000" and use Nginx to only proxy /v1/events
SPACETIMEDB_PORT=3000
