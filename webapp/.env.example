# ─── SpacetimeDB (runtime — served via /env-config.js) ───────────────────────
# The database name published to your SpacetimeDB server.
SPACETIMEDB_NAME=canal4-dev

# WebSocket URI for the SpacetimeDB server (ws:// or wss://).
# Injected at request time via /env-config.js — no rebuild needed per environment.
SPACETIMEDB_URI=wss://maincloud.spacetimedb.com

# ─── SpacetimeDB (Vite build-time fallback for `npm run dev`) ────────────────
# Only used by Vite's dev server (when window.__ENV__ hasn't been set by Express yet).
# Not needed in production Docker deployments.
VITE_SPACETIMEDB_NAME=canal4-dev
VITE_SPACETIMEDB_URI_DEV=ws://127.0.0.1:3000

# ─── SpacetimeDB Backend Secret Token ────────────────────────────────────────
# Private key authorizing the server to call protected reducers (set_email_login_pin).
# Create one with the command: "openssl rand -base64 128"
SPACETIMEDB_SERVER_PRIVATE_KEY=replace-with-your-server-private-key

# ─── SMTP (outgoing email for login PINs) ────────────────────────────────────
# Any SMTP provider works (Gmail, Sendgrid, Mailgun, Postmark, SMTP2Go, self-hosted…).
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=2525
SMTP_USER=login@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Canal4 Login PIN" <noreply@yourdomain.com>

# ─── App ─────────────────────────────────────────────────────────────────────
# Port the Express server listens on (default: 3001).
PORT=3001

# Controls whether real emails are sent.
# In development (NODE_ENV != production) PINs are only logged to the console.
NODE_ENV=production
