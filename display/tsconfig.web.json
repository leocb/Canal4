{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/env.d.ts",
    "src/**/*",
    "src/**/*.tsx",
    "src/preload/*.d.ts",
    "src/components",
    "src/module_bindings",
    "src/pages",
    "src/App.tsx",
    "src/ErrorBoundary.tsx",
    "src/i18n.ts",
    "src/main.tsx",
    "src/SpacetimeDBProvider.tsx"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": [
        "src/*"
      ]
    }
  }
}