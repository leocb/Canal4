# ─── SpacetimeDB ─────────────────────────────────────────────────────────────
# The database name to create/use on the SpacetimeDB server.
SPACETIMEDB_NAME=canal4

# WebSocket URI that browsers use to connect to SpacetimeDB.
# If behind a reverse proxy (Nginx/Caddy) with TLS, use wss://yourdomain.com
# If running locally or with direct port access, use ws://your-server-ip:3000
SPACETIMEDB_URI=ws://your-server-ip:3000

# Port to expose SpacetimeDB on the host (default: 3000).
SPACETIMEDB_PORT=3000

# Private key authorizing the server to call protected reducers (set_email_login_pin).
# Must match the key used when the module was first initialized.
# Create one with the command: "openssl rand -base64 128"
SPACETIMEDB_SERVER_PRIVATE_KEY=replace-with-your-server-private-key

# ─── SMTP (outgoing email for login PINs) ────────────────────────────────────
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=2525
SMTP_USER=login@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Canal4 Login PIN" <noreply@yourdomain.com>

# ─── Web app ─────────────────────────────────────────────────────────────────
# Port to expose the Canal4 web app on the host (default: 3001).
WEBAPP_PORT=3001
