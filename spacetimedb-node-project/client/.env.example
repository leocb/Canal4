VITE_SPACETIMEDB_NAME=your-database-name
VITE_SPACETIMEDB_URI_DEV=ws://localhost:3000
VITE_SPACETIMEDB_URI_PROD=wss://maincloud.spacetimedb.com
# Port for the express static server
PORT=3001

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
SMTP_FROM="Courier Notifications <noreply@example.com>"

# SpacetimeDB Backend Secret Token
# Generate with: openssl rand -base64 128
SPACETIMEDB_SERVER_PRIVATE_KEY=
